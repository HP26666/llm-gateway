@echo off
setlocal EnableExtensions

set "SCRIPT_DIR=%~dp0"
cd /d "%SCRIPT_DIR%"

if exist "%SCRIPT_DIR%gateway.env" (
  for /f "usebackq eol=# tokens=1,* delims==" %%A in ("%SCRIPT_DIR%gateway.env") do (
    if not "%%~A"=="" set "%%~A=%%~B"
  )
)

:parse_args
if "%~1"=="" goto after_args
set "%~1"
shift
goto parse_args

:after_args

if not defined GATEWAY_HOST set "GATEWAY_HOST=127.0.0.1"
if not defined PORT set "PORT=4000"

if not defined KIMI_BASE_URL set "KIMI_BASE_URL=https://api.kimi.com/coding/"
if not defined GLM_BASE_URL set "GLM_BASE_URL=https://open.bigmodel.cn/api/anthropic"

if not defined KIMI_AUTH_HEADER set "KIMI_AUTH_HEADER=Authorization"
if not defined KIMI_AUTH_SCHEME set "KIMI_AUTH_SCHEME=Bearer"
if not defined GLM_AUTH_HEADER set "GLM_AUTH_HEADER=Authorization"
if not defined GLM_AUTH_SCHEME set "GLM_AUTH_SCHEME=Bearer"

if not defined KIMI_MODEL set "KIMI_MODEL=kimi-for-coding"
if not defined GLM_MODEL set "GLM_MODEL=glm-5.1"

if not defined KIMI_SONNET_UPSTREAM_MODEL set "KIMI_SONNET_UPSTREAM_MODEL=%KIMI_MODEL%"
if not defined GLM_HAIKU_UPSTREAM_MODEL set "GLM_HAIKU_UPSTREAM_MODEL=glm-4.7"
if not defined GLM_OPUS_UPSTREAM_MODEL set "GLM_OPUS_UPSTREAM_MODEL=%GLM_MODEL%"

if not defined KIMI_AUTH_TOKEN if defined ANTHROPIC_API_KEY set "KIMI_AUTH_TOKEN=%ANTHROPIC_API_KEY%"

if not defined KIMI_AUTH_TOKEN (
  echo Missing KIMI_AUTH_TOKEN. Set it in gateway.env, pass KIMI_AUTH_TOKEN=... on the command line, or set ANTHROPIC_API_KEY.
  exit /b 1
)

if not defined GLM_AUTH_TOKEN (
  echo Missing GLM_AUTH_TOKEN. Set it in gateway.env or pass GLM_AUTH_TOKEN=... on the command line.
  exit /b 1
)

where node >nul 2>nul
if errorlevel 1 (
  echo Node.js not found in PATH.
  exit /b 1
)

echo Starting Claude gateway on http://%GATEWAY_HOST%:%PORT%
node "%SCRIPT_DIR%server.mjs"
