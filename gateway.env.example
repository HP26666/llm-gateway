# Copy this file to gateway.env and fill in the tokens.
# start-gateway.bat will load gateway.env automatically.

KIMI_AUTH_TOKEN=
GLM_AUTH_TOKEN=

KIMI_BASE_URL=https://api.kimi.com/coding/
GLM_BASE_URL=https://open.bigmodel.cn/api/anthropic

KIMI_MODEL=kimi-for-coding
GLM_MODEL=glm-5.1
GLM_HAIKU_UPSTREAM_MODEL=glm-4.7

PORT=4000
GATEWAY_HOST=127.0.0.1

# Optional: require Claude Code to send a gateway token.
# GATEWAY_SHARED_TOKEN=
